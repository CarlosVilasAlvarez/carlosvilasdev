---
import SocialMedia from './SocialMedia.astro';
---

<section>
    <div class="flex flex-row items-center">
        <img
            src="/myself-avatar.webp"
            alt="Me"
            class="rounded-full object-cover"
            width="64"
            height="64"
        />
        <div class="ml-5">
            <h1 class="text-base font-bold">Carlos Vilas Álvarez</h1>
            <p class="text-sm text-gray-800">Software Craftmanship</p>
            <SocialMedia />
        </div>
    </div>
    <p class="text-sm leading-relaxed text-gray-700 mt-5">
        I like to share my knowledge and thoughts as I try to improve my skills.
        Currently working at <a
            href="https://www.linkedin.com/company/holaunibo">Unibo Neobank</a
        > as a Senior Developer.
    </p>
    <p class="text-sm leading-relaxed text-slate-700 mt-2">
        Interested in software, finance, politics, and F1.
    </p>
</section>
