{
  "name": "typescript-monorepo-template",
  "version": "1.0.0",
  "description": "Template for new projects",
  "author": "Carlos Vilas Álvarez <carlosvilas@carlosvilas.dev>",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier \"packages/**/*.{ts,tsx,js,jsx,yml,json,graphql,astro}\" --plugin-search-dir=. --write",
    "format:check": "prettier \"packages/**/*.{ts,tsx,js,jsx,yml,json,graphql,astro}\" --plugin-search-dir=. --check",
    "lint": "eslint --cache ."
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "prettier-plugin-astro": "^0.12.3",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.0.2",
    "@astrojs/vercel": "^5.1.0",
    "astro": "^3.4.3",
    "dayjs": "^1.11.10",
    "reading-time": "^1.5.0",
    "tailwindcss": "^3.3.5"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=7"
  }
}
